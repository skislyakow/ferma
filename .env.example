TELEGRAM_API_ID=your_api_id_here
TELEGRAM_API_HASH=your_api_hash_here
TELEGRAM_PHONE=your_phone_here

# Yandex Translate (вместо OpenAI/DeepL)
YC_TRANSLATE_API_KEY=your_yandex_translate_api_key
YC_FOLDER_ID=your_yandex_cloud_folder_id

# Telegram Bot Token (от @BotFather — для публикации)
BOT_TOKEN=your_bot_token_here

# Source channels (comma-separated usernames)
SOURCE_CHANNELS=@channel1,@channel2,@channel3

# Target channel for publishing
TARGET_CHANNEL=@your_channel

# Schedule in hours (e.g., 3 = every 3 hours)
PUBLISH_INTERVAL_HOURS=3

# Max posts per cycle
POSTS_PER_CYCLE=2

# Language: source -> target (e.g., en -> ru, or ru -> en)
SOURCE_LANG=en
TARGET_LANG=ru

# CPA config
CPA_LINKS=https://example.com/ref1,https://example.com/ref2
CPA_INSERT_EVERY=3
