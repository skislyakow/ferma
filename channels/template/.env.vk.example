# VK-only Channel (Forest / Science / Urbanistika)
# Copy to channels/<name>/.env and fill in your values

VK_TOKEN=                # VK API access token (wall, photos scopes)
VK_GROUP_ID=             # VK public page ID (numeric, negative for wall.post)

REDDIT_SUBREDDITS=       # Comma-separated subreddit names (e.g. Forest)
REDDIT_INTERVAL=600      # Reddit polling interval in seconds

# Yandex Cloud Translate (optional, for auto-translation to Russian)
YC_TRANSLATE_API_KEY=
YC_FOLDER_ID=
