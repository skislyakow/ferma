# Telegram Bot Token (от @BotFather)
BOT_TOKEN=your_bot_token_here

# Yandex Translate
YC_TRANSLATE_API_KEY=
YC_FOLDER_ID=

# Source channels (доноры, через запятую)
SOURCE_CHANNELS=@channel1,@channel2,@channel3

# Target channel (куда постим)
TARGET_CHANNEL=@your_channel

# Schedule (часы)
PUBLISH_INTERVAL_HOURS=0.5
POSTS_PER_CYCLE=2

# Language
SOURCE_LANG=en
TARGET_LANG=ru

# CPA
CPA_LINKS=https://your-cpa-link.com/ref
CPA_INSERT_EVERY=3
