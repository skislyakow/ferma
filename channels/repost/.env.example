# RE:POST — Lightning News Channel
# Copy to .env and fill in your values

TELEGRAM_API_ID=       # From my.telegram.org
TELEGRAM_API_HASH=     # From my.telegram.org
TELEGRAM_PHONE=          # +7XXXXXXXXXX

YC_TRANSLATE_API_KEY=    # From Yandex Cloud
YC_FOLDER_ID=            # From Yandex Cloud

BOT_TOKEN=               # Create via @BotFather, add as admin to channel

SOURCE_CHANNELS=@WatcherGuru,@BNONews,@SpectatorIndex,@disclosetv,@insiderpaper

TARGET_CHANNEL=          # Your channel @username

PUBLISH_INTERVAL_HOURS=0  # unused (event-driven)
POSTS_PER_CYCLE=0         # unused

SOURCE_LANG=en
TARGET_LANG=ru

CPA_LINKS=
CPA_INSERT_EVERY=5

# RSS feeds (optional, comma-separated)
# RSS_FEEDS=https://feeds.bbci.co.uk/news/rss.xml,https://tass.ru/rss/v2.xml,https://ria.ru/export/rss2/archive/index.xml
# Russian Telegram source channels (optional, comma-separated)
# RU_SOURCE_CHANNELS=@ejdailyru,@tass_agency,@rbc_news

# VK Crosspost (optional)
# VK_TOKEN=                # VK API access token (wall, photos scopes)
# VK_GROUP_ID=             # VK public page ID (numeric, negative for wall.post)
